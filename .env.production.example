# ============================================
# Production Environment Variables for Vercel
# ============================================
# Copy this file to .env.production.local or add these variables to Vercel's environment settings
# Do NOT commit actual values to version control

# ============================================
# Database Configuration
# ============================================
# PostgreSQL connection string for Prisma ORM
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@host:5432/database_name

# ============================================
# Redis Configuration (Optional but Recommended)
# ============================================
# Redis connection string for caching and rate limiting
# Format: redis://host:port or rediss://host:port for TLS
# If not configured, the app will bypass caching and use direct database queries
REDIS_URL=redis://redis-host:6379

# ============================================
# Security & Encryption
# ============================================
# Secret key for session management (HMAC signing)
# Generate a secure random string (at least 32 characters)
# Example: openssl rand -base64 32
SESSION_SECRET=your_secure_random_session_secret_here

# AES-256 encryption key for sensitive data (access tokens, etc.)
# Must be exactly 32 characters (256 bits)
# Generate: openssl rand -base64 32 | cut -c1-32
TOKEN_ENCRYPTION_KEY=your_32_character_encryption_key_here

# ============================================
# Meta/Facebook WhatsApp Configuration
# ============================================
# Meta App Secret for webhook signature verification
# Get from: https://developers.facebook.com/apps/
META_APP_SECRET=your_meta_app_secret_here

# Verify token for WhatsApp webhook setup
# Custom token you set when configuring the webhook in Meta
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token_here

# ============================================
# Application Configuration
# ============================================
# Production application URL (for CORS and redirects)
# Example: https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ============================================
# Environment
# ============================================
# Set to 'production' for production builds
NODE_ENV=production

# ============================================
# Optional: Additional Configuration
# ============================================
# If you need to configure a custom domain for webhooks
# NEXT_PUBLIC_WEBHOOK_URL=https://your-custom-domain.com/api/webhooks/whatsapp
