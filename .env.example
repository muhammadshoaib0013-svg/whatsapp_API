# Database Configuration
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Authentication Configuration (for future NextAuth.js integration)
NEXTAUTH_SECRET="YOUR_NEXTAUTH_SECRET_HERE"
NEXTAUTH_URL="http://localhost:3000"

# Session Configuration
SESSION_SECRET="YOUR_SESSION_SECRET_HERE"

# WhatsApp / Meta Graph API Configuration (Phase 3)
WHATSAPP_GRAPH_API_VERSION="v19.0"
META_APP_ID="YOUR_META_APP_ID_HERE"
NEXT_PUBLIC_META_APP_ID="YOUR_META_APP_ID_HERE"
NEXT_PUBLIC_META_CONFIG_ID="YOUR_META_EMBEDDED_SIGNUP_CONFIG_ID_HERE"
# META_APP_SECRET is optional but recommended for webhook signature verification
META_APP_SECRET="YOUR_META_APP_SECRET_HERE_OPTIONAL_FOR_SIGNATURE_VERIFICATION"
# WHATSAPP_VERIFY_TOKEN is required for Meta webhook verification
WHATSAPP_VERIFY_TOKEN="YOUR_VERIFY_TOKEN_HERE"
# META_REDIRECT_URI for OAuth callback
META_REDIRECT_URI="http://localhost:3000/api/whatsapp/embedded-signup"

# Security Configuration
# TOKEN_ENCRYPTION_KEY must be either:
# - 64 hex characters (representing 32 bytes when decoded) - RECOMMENDED
# - 32 ASCII characters (for backward compatibility)
# To generate a secure hex key using PowerShell:
# [System.Convert]::ToHexString((New-Object byte[] 32 | ForEach-Object { (Get-Random -Maximum 256) }))
TOKEN_ENCRYPTION_KEY="YOUR_64_HEX_CHARACTERS_HERE"
# Secret rotation support (optional)
TOKEN_ENCRYPTION_KEY_V1="YOUR_64_HEX_CHARACTERS_FOR_V1"
TOKEN_ENCRYPTION_KEY_V2="YOUR_64_HEX_CHARACTERS_FOR_V2"

# Redis Configuration (optional - for caching)
REDIS_URL="redis://localhost:6379"

# Upstash Redis Configuration (for rate limiting)
UPSTASH_REDIS_REST_URL="https://your-redis-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-redis-token"

# OpenAI Configuration (for AI fallback chatbot)
OPENAI_API_KEY="sk-..."

# Stripe Configuration (for billing)
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_STARTER="price_..."
STRIPE_PRICE_GROWTH="price_..."
STRIPE_PRICE_AGENCY="price_..."

# Application Configuration
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
